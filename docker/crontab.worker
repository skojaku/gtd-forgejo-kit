# HQ worker jobs — run by supercronic inside the hq-worker service.
# 5-field cron syntax (m h dom mon dow); no user column. Paths are relative to
# the bind-mounted repo at /hq.
#
# The worker claims heavy collect jobs and runs them through hermes against the
# ollama endpoint (http://ollama:11434). It does NOT scan or triage — that is
# the hq-cron container's job. Keeping the tree current is the only shared
# concern, so it runs its own low-frequency pull.

# Keep the working tree current.
*/5  * * * * git -C /hq pull --rebase --autostash origin main

# Claim and run pending collect jobs (hermes + the large local model).
*/2  * * * * /hq/bin/hq queue work --types collect --max 1
