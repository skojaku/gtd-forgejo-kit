# Compose environment for the HQ server stack.
# Copy to .env and fill in your values (.env is gitignored).

# Host user mapping (run: id -u / id -g) — containers run as this uid:gid
UID=1000
GID=1000
# Forgejo API token for containers (interactive hosts can use ~/.config/hq/forgejo-token instead)
FORGEJO_TOKEN=your_forgejo_token_here
# Timezone for containers (single source; user.timezone in hq.yaml feeds the CLI)
TZ=America/New_York
# Address Forgejo binds to (e.g. your tailnet IP; use 127.0.0.1 for loopback-only)
HQ_BIND_IP=127.0.0.1
# Public hostname of this hub (tailnet DNS name)
HQ_DOMAIN=hq.example.ts.net
